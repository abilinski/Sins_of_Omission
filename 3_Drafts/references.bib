@misc{covid-19_statistics_defining_2020,
	title = {Defining high-value information for {COVID}-19 decision-making},
	copyright = {© 2020, Posted by Cold Spring Harbor Laboratory. This pre-print is available under a Creative Commons License (Attribution-NoDerivs 4.0 International), CC BY-ND 4.0, as described at http://creativecommons.org/licenses/by-nd/4.0/},
	url = {https://www.medrxiv.org/content/10.1101/2020.04.06.20052506v1},
	doi = {10.1101/2020.04.06.20052506},
	abstract = {Initial projections from the first generation of COVID-19 models focused public attention on worst-case scenarios in the absence of decisive policy action. These underscored the imperative for strong and immediate measures to slow the spread of infection. In the coming weeks, however, as policymakers continue enlisting models to inform decisions on COVID-19, answers to the most difficult and pressing policy questions will be much more sensitive to underlying uncertainties. In this study, we demonstrate a model-based approach to assessing the potential value of reducing critical uncertainties most salient to COVID-19 decision-making and discuss priorities for acquiring new data to reduce these uncertainties. We demonstrate how information about the impact of non-pharmaceutical interventions could narrow prediction intervals around hospitalizations over the next few weeks, while information about the prevalence of undetected cases could narrow prediction intervals around the timing and height of the peak of the epidemic.},
	language = {en},
	urldate = {2023-10-03},
	publisher = {medRxiv},
	author = {COVID-19 Statistics, Policy modeling {and} Epidemiology Collective (C-SPEC) and Bilinski, Alyssa and Birger, Ruthie and Burn, Samantha and Chitwood, Melanie and Clarke-Deelder, Emma and Copple, Tyler and Eaton, Jeffrey and Ehrlich, Hanna and Erlendsdottir, Margret and Eshghi, Soheil and Farid, Monica and Fitzpatrick, Meagan and Giardina, John and Gonsalves, Gregg and Hsieh, Yuli Lily and Iloglu, Suzan and Kao, Yu-Han and MacKay, Evan and Menzies, Nick and Mulaney, Bianca and Paltiel, David and Perniciaro, Stephanie and Phillips, Maile and Rich, Katherine and Salomon, Joshua A. and Sherak, Raphael and Shioda, Kayoko and Swartwood, Nicole and Testa, Christian and Thornhill, Thomas and White, Elizabeth and Williamson, Anne and York, Anna and Zhu, Jinyi and Zhu, Lin},
	month = apr,
	year = {2020},
	note = {Pages: 2020.04.06.20052506},
}

