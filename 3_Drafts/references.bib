@article{bianchi_involving_2021,
	title = {Involving {Pregnant} {Individuals} in {Clinical} {Research} on {COVID}-19 {Vaccines}},
	volume = {325},
	issn = {0098-7484},
	url = {https://doi.org/10.1001/jama.2021.1865},
	doi = {10.1001/jama.2021.1865},
	abstract = {The continued global escalation of coronavirus disease 2019 (COVID-19) cases is of particular concern for pregnant and lactating individuals. While many cases of COVID-19 are asymptomatic or relatively mild, recent evidence suggests that pregnant people are at increased risk of hospitalization and have a 3-fold adjusted relative risk of needing intensive care (10.5 vs 3.9/1000 cases) and mechanical ventilation (2.9 vs 1.1/1000 cases) compared with age-matched nonpregnant individuals. Pregnant people with laboratory-confirmed severe or critical COVID-19 disease have higher adjusted relative risks of cesarean delivery (1.57 [95\% CI, 1.30-1.90]), postpartum hemorrhage (2.04 [95\% CI, 1.19-3.47]), hypertensive disorders of pregnancy (1.64 [95\% CI, 1.21-2.23]), and preterm birth (3.53 [95\% CI, 2.42-5.15]).},
	number = {11},
	urldate = {2024-06-13},
	journal = {JAMA},
	author = {Bianchi, Diana W. and Kaeser, Lisa and Cernich, Alison N.},
	month = mar,
	year = {2021},
	pages = {1041--1042},
}

